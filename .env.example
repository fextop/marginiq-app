# Supabase (от создания проекта)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron secret — генерируется случайно, защищает /api/cron/* endpoints
CRON_SECRET=

# Google Ads API (заполнится после получения developer token)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# SalesDrive API (заполнится после получения API ключа в кабинете SalesDrive)
SALESDRIVE_API_KEY=
SALESDRIVE_FORM_ID=
